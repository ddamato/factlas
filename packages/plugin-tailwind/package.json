{
  "name": "@factlas/plugin-tailwind",
  "version": "4.0.0",
  "description": "Factlas plugin: extract css.class facts from Tailwind className usage (cn/clsx/cva, arbitrary values)",
  "keywords": [
    "factlas",
    "factlas-plugin",
    "tailwind",
    "tailwindcss",
    "classnames"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddamato/factlas.git",
    "directory": "packages/plugin-tailwind"
  },
  "license": "MIT",
  "author": "Donnie D'Amato",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@factlas/core": "^0.4.0",
    "tailwindcss": ">=3"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@factlas/core": "^0.4.0",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
