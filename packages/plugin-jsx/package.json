{
  "name": "@factlas/plugin-jsx",
  "version": "3.0.0",
  "description": "Factlas plugin: extract import, jsx.element, jsx.prop and jsx.attribute facts from TSX",
  "keywords": [
    "factlas",
    "factlas-plugin",
    "jsx",
    "react",
    "components",
    "imports"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddamato/factlas.git",
    "directory": "packages/plugin-jsx"
  },
  "license": "MIT",
  "author": "Donnie D'Amato",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@factlas/core": "^0.3.0"
  },
  "devDependencies": {
    "@babel/types": "^7.26.10",
    "@factlas/core": "^0.3.0",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.0"
  }
}
