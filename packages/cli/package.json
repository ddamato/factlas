{
  "name": "@factlas/cli",
  "version": "0.0.6",
  "description": "Factlas CLI: point it at a repo (locally or in CI) and emit a deterministic fact stream",
  "keywords": [
    "factlas",
    "cli",
    "design-tokens",
    "static-analysis"
  ],
  "type": "module",
  "bin": {
    "factlas": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddamato/factlas.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Donnie D'Amato",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@factlas/core": "^0.2.0",
    "@factlas/plugin-css": "^2.0.0",
    "@factlas/plugin-inline-style": "^2.0.0",
    "@factlas/plugin-jsx": "^2.0.0",
    "@factlas/plugin-styled": "^2.0.0",
    "@factlas/plugin-tailwind": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
