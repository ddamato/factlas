{
  "name": "@factlas/core",
  "version": "0.0.1",
  "description": "Deterministic, content-addressed design-system fact extraction & normalization engine",
  "keywords": [
    "design-system",
    "design-tokens",
    "static-analysis",
    "conformance",
    "facts",
    "determinism"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/fact.schema.json": "./schema/fact.schema.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "schema"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddamato/factlas.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Donnie D'Amato",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/parser": "^7.26.10",
    "@babel/traverse": "^7.26.10",
    "@babel/types": "^7.26.10",
    "culori": "4.0.1",
    "fast-glob": "3.3.2",
    "postcss": "8.4.49",
    "postcss-value-parser": "4.2.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "7.20.6",
    "@types/culori": "2.1.1",
    "@types/node": "^22.10.2",
    "ajv": "^8.17.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
