{
  "name": "@factlas/core",
  "version": "0.3.0",
  "description": "Deterministic, content-addressed design-system fact extraction & normalization engine",
  "keywords": [
    "design-system",
    "design-tokens",
    "static-analysis",
    "conformance",
    "facts",
    "determinism"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/fact.schema.json": "./schema/fact.schema.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schema"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddamato/factlas.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Donnie D'Amato",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "culori": "4.0.2",
    "fast-glob": "3.3.3",
    "postcss": "8.5.16",
    "postcss-value-parser": "4.2.0"
  },
  "devDependencies": {
    "@types/culori": "4.0.1",
    "@types/node": "^26.1.0",
    "ajv": "^8.20.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
