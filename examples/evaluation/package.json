{
  "name": "@factlas/example-evaluation",
  "version": "0.0.0",
  "private": true,
  "description": "Runnable reference: guidelines to policies, facts in a SQLite DB, evalite scoring, and a SARIF gate. Demonstration only; not part of the shipped project.",
  "type": "module",
  "bin": {
    "factlas-eval": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "design-system"
  ],
  "license": "MIT",
  "author": "Donnie D'Amato",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval": "tsup && evalite run"
  },
  "dependencies": {
    "@factlas/core": "^0.2.0",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@factlas/plugin-css": "^2.0.0",
    "@factlas/plugin-inline-style": "^2.0.0",
    "@factlas/plugin-jsx": "^2.0.0",
    "@factlas/plugin-styled": "^2.0.0",
    "@factlas/plugin-tailwind": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/sarif": "^2.1.7",
    "evalite": "^0.19.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
